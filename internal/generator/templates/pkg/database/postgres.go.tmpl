package database

import (
	"context"
	"database/sql"
	"fmt"
	"time"

	_ "github.com/lib/pq" // PostgreSQL driver
)

type DB struct {
	*sql.DB
}

// New creates a new database connection with security best practices
func New(connectionURL string) (*DB, error) {
	// Security: Validate connection string is not empty
	if connectionURL == "" {
		return nil, fmt.Errorf("database connection URL is required")
	}

	// Open connection
	db, err := sql.Open("postgres", connectionURL)
	if err != nil {
		return nil, fmt.Errorf("failed to open database: %w", err)
	}

	// Configure connection pool for security and performance
	// Security: Limit connections to prevent resource exhaustion
	db.SetMaxOpenConns(25)
	db.SetMaxIdleConns(5)
	db.SetConnMaxLifetime(5 * time.Minute)
	db.SetConnMaxIdleTime(10 * time.Minute)

	// Verify connection
	ctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()

	if err := db.PingContext(ctx); err != nil {
		return nil, fmt.Errorf("failed to ping database: %w", err)
	}

	return &DB{db}, nil
}

// Ping verifies the database connection is alive
func (db *DB) Ping(ctx context.Context) error {
	return db.PingContext(ctx)
}

// Close closes the database connection
func (db *DB) Close() error {
	return db.DB.Close()
}

// Security Best Practices:
// 1. Always use parameterized queries (sql.DB does this automatically)
// 2. Never concatenate user input into SQL strings
// 3. Use context.Context for timeouts
// 4. Limit connection pool size
// 5. Enable SSL in production (add sslmode=require to connection string)

// Example of a safe query method
func (db *DB) Query(ctx context.Context, query string, args ...interface{}) (*sql.Rows, error) {
	// Add timeout to context if not present
	if _, ok := ctx.Deadline(); !ok {
		var cancel context.CancelFunc
		ctx, cancel = context.WithTimeout(ctx, 30*time.Second)
		defer cancel()
	}

	// Security: This automatically uses parameterized queries
	return db.QueryContext(ctx, query, args...)
}

// Example of a safe exec method
func (db *DB) Exec(ctx context.Context, query string, args ...interface{}) (sql.Result, error) {
	// Add timeout to context if not present
	if _, ok := ctx.Deadline(); !ok {
		var cancel context.CancelFunc
		ctx, cancel = context.WithTimeout(ctx, 30*time.Second)
		defer cancel()
	}

	// Security: This automatically uses parameterized queries
	return db.ExecContext(ctx, query, args...)
}

// Transaction wrapper for safe transaction handling
func (db *DB) BeginTx(ctx context.Context) (*sql.Tx, error) {
	return db.DB.BeginTx(ctx, &sql.TxOptions{
		Isolation: sql.LevelReadCommitted,
	})
}
